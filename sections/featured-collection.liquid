<style>
  .aw-collection {
    padding: 100px 40px;
    background: #fff;
  }
  .aw-collection__inner { max-width: 1280px; margin: 0 auto; }
  .aw-collection__label {
    font-size: 0.7rem; text-transform: uppercase; letter-spacing: 3px;
    color: #c17f59; margin-bottom: 16px; font-weight: 500;
  }
  .aw-collection__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    color: #2c2420; margin-bottom: 16px; line-height: 1.2;
  }
  .aw-collection__desc {
    font-size: 1.05rem; color: #6b5e53; max-width: 640px;
    line-height: 1.8; font-weight: 300; margin-bottom: 48px;
  }
  .aw-collection__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 28px;
  }
  .aw-product-card {
    background: #faf7f2; border-radius: 12px; overflow: hidden;
    transition: all 0.4s;
  }
  .aw-product-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.08);
  }
  .aw-product-card__img {
    aspect-ratio: 1; overflow: hidden; background: #e8e3d8; position: relative;
  }
  .aw-product-card__img img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.6s;
  }
  .aw-product-card:hover .aw-product-card__img img { transform: scale(1.05); }
  .aw-product-card__body { padding: 16px; }
  .aw-product-card__type {
    font-size: 0.72rem; color: #c4a882; text-transform: uppercase;
    letter-spacing: 1px; margin-bottom: 8px;
  }
  .aw-product-card__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1rem; color: #2c2420; margin-bottom: 6px;
    line-height: 1.3; display: -webkit-box; -webkit-line-clamp: 2;
    -webkit-box-orient: vertical; overflow: hidden;
  }
  .aw-product-card__price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem; color: #8b7355; font-weight: 600;
  }
  .aw-product-card__link {
    text-decoration: none; color: inherit;
  }
  @media (max-width: 768px) {
    .aw-collection { padding: 60px 20px; }
    .aw-collection__grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
  }
</style>

<section class="aw-collection">
  <div class="aw-collection__inner">
    <p class="aw-collection__label">{{ section.settings.label | default: "The Collection" }}</p>
    <h2 class="aw-collection__title">{{ section.settings.title | default: "Curated for Your Home" }}</h2>
    <p class="aw-collection__desc">{{ section.settings.description | default: "Handcrafted pieces across multiple categories. Each one chosen for its beauty, utility, and soul." }}</p>

    {%- assign collection = collections[section.settings.collection] -%}
    {%- if collection != blank -%}
      <div class="aw-collection__grid">
        {%- for product in collection.products limit: section.settings.products_to_show -%}
          <div class="aw-product-card">
            <a href="{{ product.url }}" class="aw-product-card__link">
              <div class="aw-product-card__img">
                {%- if product.featured_image -%}
                  {{ product.featured_image | image_url: width: 400 | image_tag: loading: 'lazy', alt: product.title }}
                {%- else -%}
                  <div style="display:flex;align-items:center;justify-content:center;height:100%;color:#c4a882;font-family:'Cormorant Garamond',serif;font-size:1.2rem">Atelier<br>Wabi</div>
                {%- endif -%}
              </div>
              <div class="aw-product-card__body">
                <p class="aw-product-card__type">{{ product.type }}</p>
                <h3 class="aw-product-card__title">{{ product.title }}</h3>
                <p class="aw-product-card__price">{{ product.price | money }}</p>
              </div>
            </a>
          </div>
        {%- endfor -%}
      </div>
    {%- else -%}
      <p style="color:#6b5e53;text-align:center;padding:60px">
        Create a collection in your Shopify admin and assign it to this section.
      </p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "The Collection"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Curated for Your Home"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Handcrafted pieces across multiple categories. Each one chosen for its beauty, utility, and soul."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 4,
      "max": 50,
      "step": 1,
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Featured Collection",
      "category": "Collection"
    }
  ]
}
{% endschema %}
