<style>
  .aw-product-page {
    padding: 80px 40px;
    background: #faf7f2;
    min-height: 70vh;
  }
  .aw-product-page__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }
  .aw-product-page__gallery {
    position: sticky;
    top: 100px;
  }
  .aw-product-page__main-img {
    aspect-ratio: 1;
    background: #ede8e0;
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 16px;
  }
  .aw-product-page__main-img img {
    width: 100%; height: 100%;
    object-fit: cover;
  }
  .aw-product-page__thumbnails {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .aw-product-page__thumb {
    width: 72px; height: 72px;
    border-radius: 8px;
    overflow: hidden;
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 0.2s;
  }
  .aw-product-page__thumb:hover,
  .aw-product-page__thumb.active {
    border-color: #8b7355;
  }
  .aw-product-page__thumb img {
    width: 100%; height: 100%;
    object-fit: cover;
  }
  .aw-product-page__info {
    padding-top: 8px;
  }
  .aw-product-page__type {
    font-size: 0.72rem;
    color: #c17f59;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 12px;
  }
  .aw-product-page__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    color: #2c2420;
    line-height: 1.2;
    margin-bottom: 20px;
  }
  .aw-product-page__price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    color: #8b7355;
    font-weight: 600;
    margin-bottom: 28px;
  }
  .aw-product-page__divider {
    height: 1px;
    background: #e8e3d8;
    margin: 24px 0;
  }
  .aw-product-page__desc {
    font-size: 1rem;
    color: #6b5e53;
    line-height: 1.85;
    font-weight: 300;
    margin-bottom: 32px;
  }
  .aw-product-page__variants {
    margin-bottom: 28px;
  }
  .aw-product-page__variants label {
    display: block;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #2c2420;
    margin-bottom: 10px;
  }
  .aw-product-page__variant-btns {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .aw-product-page__variant-btn {
    padding: 8px 18px;
    border: 1.5px solid #d4cec4;
    background: transparent;
    border-radius: 4px;
    font-size: 0.9rem;
    color: #2c2420;
    cursor: pointer;
    transition: all 0.2s;
  }
  .aw-product-page__variant-btn:hover,
  .aw-product-page__variant-btn.selected {
    border-color: #8b7355;
    background: #8b7355;
    color: #fff;
  }
  .aw-product-page__qty {
    display: flex;
    align-items: center;
    gap: 0;
    margin-bottom: 24px;
    width: fit-content;
    border: 1.5px solid #d4cec4;
    border-radius: 4px;
    overflow: hidden;
  }
  .aw-product-page__qty-btn {
    width: 40px; height: 44px;
    background: transparent;
    border: none;
    font-size: 1.2rem;
    color: #2c2420;
    cursor: pointer;
    transition: background 0.2s;
  }
  .aw-product-page__qty-btn:hover { background: #f0ebe1; }
  .aw-product-page__qty-input {
    width: 50px; height: 44px;
    border: none;
    border-left: 1.5px solid #d4cec4;
    border-right: 1.5px solid #d4cec4;
    text-align: center;
    font-size: 1rem;
    color: #2c2420;
    background: transparent;
  }
  .aw-product-page__add-btn {
    width: 100%;
    padding: 16px;
    background: #8b7355;
    color: #fff;
    border: none;
    border-radius: 50px;
    font-size: 0.95rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s;
    margin-bottom: 14px;
  }
  .aw-product-page__add-btn:hover {
    background: #2c2420;
    transform: translateY(-2px);
  }
  .aw-product-page__buy-btn {
    width: 100%;
    padding: 16px;
    background: transparent;
    color: #8b7355;
    border: 1.5px solid #8b7355;
    border-radius: 50px;
    font-size: 0.95rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s;
    margin-bottom: 28px;
  }
  .aw-product-page__buy-btn:hover {
    background: #8b7355;
    color: #fff;
  }
  .aw-product-page__features {
    list-style: none;
    padding: 0; margin: 0;
  }
  .aw-product-page__features li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.9rem;
    color: #6b5e53;
    padding: 6px 0;
  }
  .aw-product-page__features li::before {
    content: '✦';
    color: #c17f59;
    font-size: 0.6rem;
  }
  @media (max-width: 768px) {
    .aw-product-page { padding: 40px 20px; }
    .aw-product-page__inner { grid-template-columns: 1fr; gap: 32px; }
    .aw-product-page__gallery { position: static; }
  }
</style>

{%- assign current_variant = product.selected_or_first_available_variant -%}

<section class="aw-product-page">
  <div class="aw-product-page__inner">

    {%- comment -%} Gallery {%- endcomment -%}
    <div class="aw-product-page__gallery">
      <div class="aw-product-page__main-img" id="aw-main-img">
        {%- if product.featured_image -%}
          {{ product.featured_image | image_url: width: 800 | image_tag: id: 'aw-main-img-tag', loading: 'eager', alt: product.title }}
        {%- else -%}
          <div style="display:flex;align-items:center;justify-content:center;height:100%;color:#c4a882;font-family:'Cormorant Garamond',serif;font-size:2rem;letter-spacing:4px">Atelier Wabi</div>
        {%- endif -%}
      </div>

      {%- if product.images.size > 1 -%}
        <div class="aw-product-page__thumbnails">
          {%- for image in product.images limit: 6 -%}
            <div class="aw-product-page__thumb {% if forloop.first %}active{% endif %}"
              onclick="document.getElementById('aw-main-img-tag').src='{{ image | image_url: width: 800 }}';
                       document.querySelectorAll('.aw-product-page__thumb').forEach(t=>t.classList.remove('active'));
                       this.classList.add('active')">
              {{ image | image_url: width: 150 | image_tag: alt: product.title }}
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Product Info {%- endcomment -%}
    <div class="aw-product-page__info">
      <p class="aw-product-page__type">{{ product.type | default: 'Home Decor' }}</p>
      <h1 class="aw-product-page__title">{{ product.title }}</h1>
      <p class="aw-product-page__price">{{ current_variant.price | money }}</p>

      <div class="aw-product-page__divider"></div>

      <div class="aw-product-page__desc">{{ product.description }}</div>

      {%- form 'product', product, id: 'aw-product-form' -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}">

        {%- if product.has_only_default_variant == false -%}
          {%- for option in product.options_with_values -%}
            <div class="aw-product-page__variants">
              <label>{{ option.name }}</label>
              <div class="aw-product-page__variant-btns">
                {%- for value in option.values -%}
                  <button type="button" class="aw-product-page__variant-btn{% if option.selected_value == value %} selected{% endif %}">
                    {{ value }}
                  </button>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}

        <div class="aw-product-page__qty">
          <button type="button" class="aw-product-page__qty-btn" onclick="let i=this.nextElementSibling;if(i.value>1)i.value--">−</button>
          <input type="number" name="quantity" value="1" min="1" class="aw-product-page__qty-input">
          <button type="button" class="aw-product-page__qty-btn" onclick="this.previousElementSibling.value++">+</button>
        </div>

        <button type="submit" name="add" class="aw-product-page__add-btn">
          Add to Cart
        </button>
      {%- endform -%}

      <div class="aw-product-page__divider"></div>

      <ul class="aw-product-page__features">
        <li>Handcrafted with natural materials</li>
        <li>Wabi-sabi inspired design</li>
        <li>Free shipping in Germany over €49</li>
        <li>30-day return guarantee</li>
        <li>Carbon-neutral packaging</li>
      </ul>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Product Page",
  "settings": []
}
{% endschema %}
